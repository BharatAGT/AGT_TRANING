# Table 50101 - Inventory Adjustment Line

```al
Table 50101 "Inventory Adjustment Line"
{
    DataClassification = ToBeClassified;

    fields
    {
        field(1; "Adjustment No."; Code[20])
        {
            TableRelation = "Inventory Adjustment Header"."Adjustment No.";
        }

        field(2; "Line No."; Integer)
        {
        }

        field(3; "Item No."; Code[20])
        {
            TableRelation = Item."No.";

            trigger OnValidate()
            var
                ItemRec: Record Item;
            begin
                if ItemRec.Get("Item No.") then
                    Description := ItemRec.Description;
            end;
        }

        field(4; Description; Text[100])
        {
        }

        field(5; Quantity; Decimal)
        {
            trigger OnValidate()
            begin
                if Quantity = 0 then
                    Error('Quantity cannot be zero');

                "Total Cost" := Quantity * "Unit Cost";
            end;
        }

        field(6; "Unit Cost"; Decimal)
        {
            trigger OnValidate()
            begin
                "Total Cost" := Quantity * "Unit Cost";
            end;
        }

        field(7; "Total Cost"; Decimal)
        {
            Editable = false;
        }
    }

    keys
    {
        key(PK; "Adjustment No.", "Line No.")
        {
            Clustered = true;
        }
    }
}
