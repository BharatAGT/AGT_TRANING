# Codeunit 50100 - Approval Management

```al
codeunit 50100 "Approval Management"
{
    procedure SendForApproval(var Header: Record "Inventory Adjustment Header")
    var
        LineRec: Record "Inventory Adjustment Line";
    begin
        if Header.Status <> Header.Status::Open then
            Error('Document must be Open');

        LineRec.SetRange("Adjustment No.", Header."Adjustment No.");

        if not LineRec.FindFirst() then
            Error('Lines must exist');

        OnBeforeApproval(Header);

        Header.Status := Header.Status::"Pending Approval";
        Header.Modify();

        Message('Document sent for approval');

        OnAfterApproval(Header);
    end;

    procedure ApproveDocument(var Header: Record "Inventory Adjustment Header")
    var
        LineRec: Record "Inventory Adjustment Line";
    begin
        if Header.Status <> Header.Status::"Pending Approval" then
            Error('Document must be pending approval');

        LineRec.SetRange("Adjustment No.", Header."Adjustment No.");

        if not LineRec.FindFirst() then
            Error('Lines must exist');

        OnBeforeApproval(Header);

        Header.Status := Header.Status::Approved;
        Header."Approved By" := UserId;
        Header.Modify();

        Message('Document approved');

        OnAfterApproval(Header);
    end;

    [IntegrationEvent(false, false)]
    procedure OnBeforeApproval(var Header: Record "Inventory Adjustment Header")
    begin
    end;

    [IntegrationEvent(false, false)]
    procedure OnAfterApproval(var Header: Record "Inventory Adjustment Header")
    begin
    end;
}
